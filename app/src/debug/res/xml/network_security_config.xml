<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Debug builds: allow cleartext only for localhost (emulator/device testing) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext for localhost / emulator loopback only in debug -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

    <!-- PaceDream frontend domain -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">pacedream.com</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>

    <!-- PaceDream API backend on Render -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">onrender.com</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>

    <!-- Auth0 authentication service -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">auth0.com</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
</network-security-config>
