<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Disallow cleartext (HTTP) traffic for all domains -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!--
        Certificate pinning for the PaceDream API + frontend domains is
        intentionally NOT enabled yet. A <pin-set> previously shipped here
        with placeholder SPKI hashes, which the platform *enforces* on
        release builds — every TLS connection to api.pacedream.com failed
        pin validation, taking the whole app offline (debug builds were
        unaffected only because <debug-overrides> bypasses pins).

        Per CERT_PINNING_PLAN.md, do not re-add a <pin-set> until the
        rotation prerequisites are met (real intermediate SPKI hashes,
        a pre-loaded backup intermediate on the CDN, Crashlytics pin-failure
        telemetry, and a rotation owner). The plan contains the exact XML
        to restore and the procedure to compute the hashes.
    -->
    <domain-config>
        <domain includeSubdomains="true">api.pacedream.com</domain>
        <domain includeSubdomains="true">www.pacedream.com</domain>
        <domain includeSubdomains="true">pacedream.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!--
        Debug-only overrides: trust user-installed CAs so engineers can
        proxy through Charles / mitmproxy on debug builds. Automatically
        ignored on release builds because <debug-overrides> only applies
        when android:debuggable="true" — i.e. the BuildConfig.DEBUG gate
        is enforced by the platform, not by us.
    -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
